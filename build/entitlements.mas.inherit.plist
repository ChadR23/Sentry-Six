<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Sandbox required for all child processes in MAS -->
    <key>com.apple.security.app-sandbox</key>
    <true/>

    <!-- Inherit sandbox permissions from parent -->
    <key>com.apple.security.inherit</key>
    <true/>

    <!-- Required for Electron helper processes (renderer, GPU, plugin) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!-- Required for Node.js in renderer/helper processes -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Required for native modules in helper processes -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
