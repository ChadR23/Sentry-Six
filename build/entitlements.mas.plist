<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required for Mac App Store sandbox -->
    <key>com.apple.security.app-sandbox</key>
    <true/>

    <!-- Required for Electron's V8 JavaScript engine (JIT compilation) -->
    <!-- Review Note: Electron uses V8 which requires JIT for performance -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!-- Required for Node.js runtime -->
    <!-- Review Note: Node.js requires writable executable memory pages -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Required for native Node addons (canvas, node-machine-id) -->
    <!-- Review Note: Native modules loaded at runtime require this -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Required for user-selected dashcam drive access -->
    <!-- User selects their Tesla USB drive via open panel; app reads dashcam footage -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>

    <!-- Required for outbound network access -->
    <!-- Used for: map tile fetching, Sentry Studio share/upload feature, anonymous version telemetry -->
    <key>com.apple.security.network.client</key>
    <true/>
</dict>
</plist>
